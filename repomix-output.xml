package com.example.expensetracker;

import android.graphics.Color;
import java.util.HashMap;
import java.util.Map;

public class CategoryColorMapper {
    private static final Map<String, Integer> colorMap = new HashMap<>();

    static {
        colorMap.put("Еда", Color.parseColor("#FF9800"));        // Оранжевый
        colorMap.put("Транспорт", Color.parseColor("#2196F3")); // Синий
        colorMap.put("Развлечения", Color.parseColor("#9C27B0")); // Фиолетовый
        colorMap.put("Прочее", Color.parseColor("#607D8B"));     // Серый
    }

    public static int getColor(String category) {
        Integer color = colorMap.get(category);
        return (color != null) ? color : Color.parseColor("#E91E63"); // Розовый по умолчанию
    }
}
